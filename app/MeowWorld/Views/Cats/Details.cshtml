@model MeowWorld.Models.Cat

@{
    ViewData["Title"] = "猫詳細";
}

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <h1 class="h3 mb-3">猫詳細</h1>

            <div class="card shadow-sm">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">名前</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">年齢</dt>
                        <dd class="col-sm-8">@Model.Age</dd>

                        <dt class="col-sm-4">品種</dt>
                        <dd class="col-sm-8">@Model.Breed</dd>

                        <dt class="col-sm-4">説明</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

                        <dt class="col-sm-4">登録日時</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</dd>
                    </dl>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">編集</a>
                <a asp-action="Index" class="btn btn-outline-secondary">一覧に戻る</a>
            </div>
        </div>
    </div>
</div>