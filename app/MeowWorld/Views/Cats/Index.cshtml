@model IEnumerable<MeowWorld.Models.Cat>

@{
    ViewData["Title"] = "猫一覧";
}

<div class="container py-3">
    <div class="row mb-3 align-items-center">
        <div class="col-12 col-md-6">
            <h1 class="h3 mb-0">猫一覧</h1>
        </div>
        <div class="col-12 col-md-6 text-md-end mt-2 mt-md-0">
            <a asp-action="Create" class="btn btn-outline-dark px-4">＋ 新しい猫を登録</a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-bordered align-middle bg-white">
                    <thead class="text-center">
                        <tr>
                            <th class="text-nowrap" style="width: 80px;">ID</th>
                            <th>名前</th>
                            <th class="text-nowrap" style="width: 90px;">Age</th>
                            <th>Breed</th>
                            <th class="text-nowrap">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Id</td>
                            <td class="text-center">@item.Name</td>
                            <td class="text-center">@item.Age</td>
                            <td>@item.Breed</td>
                            <td class="text-nowrap text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">詳細</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">編集</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">削除</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>